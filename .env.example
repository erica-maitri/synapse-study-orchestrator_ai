# Synapse Server Config
PORT=8000
HOST=127.0.0.1

# Ollama Endpoint Configuration
# Set OPENAI_API_BASE to redirect LiteLLM requests to Ollama
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# Security & Authentication
JWT_SECRET=super_secret_synapse_key_change_me_in_prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Sandboxed Workspace Path
# Absolute path to restricted file operations folder
# (Automatically resolved in Python if left relative/blank)
SANDBOX_DIR=mcp_server/sandbox
